{
  "name": "the-toster/hdrtr",
  "config": {
    "optimize-autoloader": false,
    "preferred-install": "dist",
    "sort-packages": true,
    "audit": {
      "ignore": ["PKSA-z3gr-8qht-p93v"]
    }
  },
  "description": "Hydrator with PHPDoc types support",
  "type": "library",
  "require": {
    "php": "^8.3",
    "phpstan/phpdoc-parser": "^2.3",
    "typhoon/type": "^0.7"
  },
  "autoload": {
    "psr-4": {
      "Hdrtr\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Hdrtr\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12.4.4"
  }
}
