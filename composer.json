{
    "name": "the-toster/hdrtr",
    "config": {
        "optimize-autoloader": false,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "description": "hydrator",
    "type": "library",
    "require": {
        "php": "^8.3",
        "typhoon/type": "^0.7"
    },
    "autoload": {
        "psr-4": {
            "Hdrtr\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hdrtr\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^12.4.4",
        "vimeo/psalm": "^6.13.1"
    }
}
